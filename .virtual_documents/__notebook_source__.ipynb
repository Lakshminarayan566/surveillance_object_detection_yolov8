get_ipython().getoutput("pip install ultralytics")


get_ipython().getoutput("pip install gdown")


get_ipython().getoutput("gdown --id 1KvTi4rWcrQLQTkXaGTzjc9TDJOYr_ZuI -O visdrone_dataset.zip")


get_ipython().getoutput("unzip visdrone_dataset.zip -d /kaggle/working/detection")


yaml_content = """
path: /kaggle/working/detection/visdrone_clean/datasets
train: images/train
val: images/val

nc: 10
names:
  0: pedestrian
  1: people
  2: bicycle
  3: car
  4: van
  5: truck
  6: tricycle
  7: awning-tricycle
  8: bus
  9: motor
"""

with open("/kaggle/working/detection/dataset.yaml", "w") as f:
    f.write(yaml_content)

print("dataset.yaml created")


from ultralytics import YOLO

model = YOLO("yolov8l.pt")

model.train(
    data="/kaggle/working/detection/dataset.yaml",
    epochs=70,
    imgsz=896,
    batch=12,
    device=[0,1],
    project="runs/detect",
    name="defence_kaggle_upgrade"
)


get_ipython().getoutput("find /kaggle/working -name best.pt")


get_ipython().getoutput("cp /kaggle/working/runs/detect/runs/detect/defence_kaggle_upgrade3/weights/best.pt /kaggle/working/")


get_ipython().getoutput("ls /kaggle/working")


from ultralytics import YOLO

model = YOLO("/kaggle/working/runs/detect/defence_kaggle_upgrade/weights/best.pt")

metrics = model.val(data="/kaggle/working/detection/dataset.yaml")

print("mAP@0.5:", metrics.box.map50)
print("mAP@0.5:0.95:", metrics.box.map)
